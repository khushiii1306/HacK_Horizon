# FoodLoop AI Environment Variables
# Copy this file to .env and update values as needed

# App Configuration
VITE_APP_NAME=FoodLoop AI
VITE_APP_VERSION=1.0.0

# API Configuration (when adding backend)
VITE_API_URL=http://localhost:3001
VITE_API_TIMEOUT=30000

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_MAPS=false

# Map Configuration (if using Google Maps)
VITE_GOOGLE_MAPS_API_KEY=your_key_here
VITE_DEFAULT_LAT=23.1815
VITE_DEFAULT_LNG=79.9864
VITE_DEFAULT_ZOOM=12

# Location (Dhanbad, Jharkhand by default)
VITE_CITY=Dhanbad
VITE_STATE=Jharkhand
VITE_COUNTRY=India
